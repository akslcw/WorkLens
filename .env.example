# Host ports used by the one-command Docker Compose path.
WORKLENS_FRONTEND_PORT=5173
WORKLENS_BACKEND_PORT=8080
WORKLENS_DB_PORT=5432

# Database defaults. WORKLENS_DB_HOST remains 127.0.0.1 for local development;
# Compose overrides the backend container to use the postgres service name.
WORKLENS_DB_HOST=127.0.0.1
WORKLENS_DB_NAME=worklens
WORKLENS_DB_USERNAME=worklens
WORKLENS_DB_PASSWORD=change-me

# Optional. Leave empty to start the full stack with an invalid placeholder
# credential; LLM calls return a provider error while non-LLM features remain available.
WORKLENS_DEEPSEEK_API_KEY=
WORKLENS_DEEPSEEK_BASE_URL=https://api.deepseek.com
WORKLENS_DEEPSEEK_MODEL=deepseek-v4-flash
WORKLENS_DEEPSEEK_CONNECT_TIMEOUT=5s
WORKLENS_DEEPSEEK_READ_TIMEOUT=15s

# Optional report schedule overrides.
WORKLENS_REPORTS_DAILY_CRON=0 55 23 * * *
WORKLENS_REPORTS_WEEKLY_CRON=0 55 23 * * SUN
WORKLENS_REPORTS_MONTHLY_CRON=0 55 23 28-31 * *
WORKLENS_REPORTS_ZONE=Asia/Hong_Kong
